{
  "name": "treeji",
  "version": "0.1.0",
  "description": "Git worktree manager with JIRA integration",
  "type": "module",
  "bin": {
    "treeji": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@napi-rs/keyring": "^1.2.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "execa": "^9.6.1",
    "jira.js": "^5.3.1",
    "open": "^11.0.0",
    "slugify": "^1.6.9",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
